# Copy to .env (or export) for local development. Azure values come from ACA secrets.
API_KEY=dev-secret-key
DATABASE_URL=sqlite:///./local.db
# Open /docs without a key (local dev only; leave unset in Azure)
EXPOSE_DOCS=true
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/acme
MOCK_FMCSA=true
FMCSA_WEBKEY=
NEGOTIATION_THRESHOLDS=0.12,0.08,0.04
